{
  "info": {
    "name": "Todo Task Manager API",
    "description": "API collection untuk Todo/Task Manager Backend Project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["health"]
        },
        "description": "Check if server is running"
      }
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["tasks"]
            },
            "description": "Get all tasks from the server"
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/tasks/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["tasks", "1"]
            },
            "description": "Get specific task by ID (change ID number as needed)"
          }
        },
        {
          "name": "Create New Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Belajar Golang\",\n  \"description\": \"Memahami REST API dengan Golang\", \"priority\": \"Rendah\", \"completed\": false\n}"
            },
            "url": {
              "raw": "http://localhost:8080/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["tasks"]
            },
            "description": "Create a new task"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Belajar Golang Advanced\",\n  \"description\": \"Sudah lebih paham tentang REST API\", \"priority\": \"Tinggi\", \"completed\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8080/tasks/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["tasks", "1"]
            },
            "description": "Update existing task (change ID number as needed)"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/tasks/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["tasks", "1"]
            },
            "description": "Delete a task (change ID number as needed)"
          }
        }
      ]
    }
  ]
}
